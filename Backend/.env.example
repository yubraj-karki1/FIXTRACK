PORT=4000
SERVICE_NAME=FixTrack backend
PUBLIC_ORIGIN=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
MONGODB_URI=
MONGODB_DATABASE=fixtrack
SEED_DEMO_DATA=true

# Production must use HTTPS. Set TRUST_PROXY=true behind a TLS-terminating proxy,
# or set both certificate paths for direct Node HTTPS. Never trust arbitrary proxy headers.
TRUST_PROXY=false
REQUIRE_HTTPS=true
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# Use a cryptographically random value of at least 32 characters in production.
# Leaving this blank intentionally makes production fail fast instead of using a placeholder secret.
JWT_SECRET=
JWT_ISSUER=fixtrack-api
JWT_AUDIENCE=fixtrack-web
JWT_EXPIRES_IN_SECONDS=28800

# Disabled by default. The HttpOnly session cookie is the only supported credential;
# only enable this for a non-browser client that cannot hold cookies, and only over HTTPS.
ALLOW_BEARER_FALLBACK=false

# Separate key used to encrypt authenticator secrets at rest. Use 32+ random characters.
TOTP_ENCRYPTION_KEY=

# Resend API key (https://resend.com/api-keys) and verified "from" address, used to send
# password reset code emails. Leaving these blank disables email delivery (logged as an error).
RESEND_API_KEY=
EMAIL_FROM=

# --- Image uploads (profile avatars, complaint evidence photos) ---
# Absolute or process.cwd()-relative path outside any static/web-served directory. Files are
# only ever readable through the authenticated GET /api/uploads/:id route - never directly.
UPLOAD_DIR=
MAX_UPLOAD_BYTES=5242880
MAX_IMAGE_DIMENSION_PX=5000
MAX_CONCURRENT_UPLOADS_PER_USER=2

# ClamAV malware scanning. Off by default so local development without a running clamd is not
# blocked. Set to true in production and point at a reachable clamd - uploads fail closed
# (are rejected) if this is enabled but the daemon cannot be reached.
CLAMAV_ENABLED=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# Optional S3-compatible storage instead of local disk. The bucket must have S3 Block Public
# Access enabled; objects are written with a private ACL and read back via short-lived signed
# URLs. Uses the standard AWS SDK credential chain (env vars, shared config, or instance role).
UPLOAD_S3_ENABLED=false
UPLOAD_S3_BUCKET=
UPLOAD_S3_REGION=
UPLOAD_S3_SIGNED_URL_TTL_SECONDS=300
