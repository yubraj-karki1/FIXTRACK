PORT=4000
SERVICE_NAME=FixTrack backend
CORS_ORIGIN=http://localhost:3000
MONGODB_URI=
MONGODB_DATABASE=fixtrack

# Use a cryptographically random value of at least 32 characters in production.
# Leaving this blank intentionally makes production fail fast instead of using a placeholder secret.
JWT_SECRET=
JWT_ISSUER=fixtrack-api
JWT_AUDIENCE=fixtrack-web
JWT_EXPIRES_IN_SECONDS=28800

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
GOOGLE_SUCCESS_REDIRECT=http://localhost:3000/login
